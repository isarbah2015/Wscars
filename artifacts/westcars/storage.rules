rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Car images — public read, uploader must own the path ─────────────
    match /cars/{carId}/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── User avatars — public read ────────────────────────────────────────
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Chat media — participants only ────────────────────────────────────
    match /chat/{convId}/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── ID verification — private, owner only ────────────────────────────
    match /id-verification/{userId}/{filename} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
