{
  "expo": {
    "name": "Westcars",
    "slug": "westcars",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "westcars",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/logo_transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628",
      "dark": {
        "image": "./assets/images/logo_transparent.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A1628"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "gh.westcars.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Westcars needs access to your photos to upload car images.",
        "NSLocationWhenInUseUsageDescription": "Westcars uses your location to show cars near you and to attach a location to your listings."
      }
    },
    "android": {
      "package": "gh.westcars.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_transparent.png",
        "backgroundColor": "#0A1628"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Westcars needs access to your photos to upload car images.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e61e8d7b-541e-491c-afa1-219ca6f64d2d"
      }
    },
    "owner": "lyon7sarbah"
  }
}
