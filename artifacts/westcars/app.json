{
  "expo": {
    "name": "Westcars",
    "slug": "westcars",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "westcars",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/wc-logomark.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628",
      "dark": {
        "image": "./assets/images/wc-logomark.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A1628"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "gh.westcars.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Westcars needs camera access to take photos of cars you want to list.",
        "NSPhotoLibraryUsageDescription": "Westcars needs access to your photos to upload car images.",
        "NSLocationWhenInUseUsageDescription": "Westcars uses your location to show cars near you and to attach a location to your listings."
      }
    },
    "android": {
      "package": "gh.westcars.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wc-logomark.png",
        "backgroundColor": "#0A1628"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Westcars needs access to your photos to upload car images.",
          "cameraPermission": "Westcars needs camera access to take photos of cars you want to list."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
