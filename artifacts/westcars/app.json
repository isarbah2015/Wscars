{
  "expo": {
    "name": "Westcars",
    "slug": "westcars",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wc-new-logo.jpg",
    "scheme": "westcars",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/wc-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628",
      "dark": {
        "image": "./assets/images/wc-logo.png",
        "resizeMode": "contain",
        "backgroundColor": "#0A1628"
      }
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "gh.westcars.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Westcars needs access to your photos to upload car images.",
        "NSLocationWhenInUseUsageDescription": "Westcars uses your location to show cars near you and to attach a location to your listings.",
        "NSMicrophoneUsageDescription": "Westcars needs microphone access to send voice messages."
      }
    },
    "android": {
      "package": "gh.westcars.app",
      "versionCode": 2,
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/wc-logo.png",
        "backgroundColor": "#0A1628"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/wc-new-logo.jpg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Westcars uses your location to show cars near you and to attach a location to your listings."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Westcars needs microphone access to send voice messages."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Westcars needs access to your photos to upload car images.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e61e8d7b-541e-491c-afa1-219ca6f64d2d"
      }
    },
    "owner": "lyon7sarbah",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e61e8d7b-541e-491c-afa1-219ca6f64d2d"
    }
  }
}
