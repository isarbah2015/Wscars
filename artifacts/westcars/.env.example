# Copy to .env — never commit .env
# Firebase (required for production)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In (iOS production builds — also bundled via google-services.json fallback)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=778261594022-xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Paystack — public test/live key (app checkout only)
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Cloud Functions region (match firebase deploy output)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Local Functions emulator (optional)
# EXPO_PUBLIC_USE_FUNCTIONS_EMULATOR=1

# Paystack SECRET — server only (never here):
#   cd firebase && firebase functions:secrets:set PAYSTACK_SECRET_KEY
