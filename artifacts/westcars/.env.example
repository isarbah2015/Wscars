# Copy to .env — never commit .env
# Firebase (required for production)
# Expo Go: use the WEB app API key + app id (not the Android key from google-services.json).
# Android-restricted keys cause: auth/requests-from-this-android-client-application-<empty>-are-blocked
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=1:778261594022:web:fd731c1448c97750b91967
# iOS-only Firebase app id (optional — defaults from google-services-ios.json)
EXPO_PUBLIC_FIREBASE_IOS_APP_ID=1:778261594022:ios:394811276bf08a17b91967

# Google Sign-In (iOS production builds — also bundled via google-services.json fallback)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=778261594022-xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Paystack hosted checkout — callback deep link (must match app.json scheme westcars)
EXPO_PUBLIC_PAYSTACK_CALLBACK_URL=westcars://paystack/callback

# Optional legacy — not used by hosted checkout (secret stays on Firebase only)
# EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Local testing only:
# EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Cloud Functions region (match firebase deploy output)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Boost Paystack HTTP APIs (defaults to cloudfunctions.net URLs if unset)
# EXPO_PUBLIC_BOOST_PAYMENT_INIT_URL=https://us-central1-westcar-5c1e6.cloudfunctions.net/boostPaymentInitialize
# EXPO_PUBLIC_BOOST_PAYMENT_VERIFY_URL=https://us-central1-westcar-5c1e6.cloudfunctions.net/boostPaymentVerify

# Local Functions emulator (optional)
# EXPO_PUBLIC_USE_FUNCTIONS_EMULATOR=1

# Paystack SECRET — server only (never here):
#   cd firebase && firebase functions:secrets:set PAYSTACK_SECRET_KEY
