# Copy to .env and fill in your Paystack keys (never commit .env).
# Public key only — safe for the Expo app bundle.
EXPO_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Optional: Cloud Functions region (default us-central1). Set after first deploy.
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=us-central1

# Local emulator for boost payment functions (optional)
# EXPO_PUBLIC_USE_FUNCTIONS_EMULATOR=1

# Secret key — Firebase Functions ONLY (never in this file for production):
#   cd firebase && firebase functions:secrets:set PAYSTACK_SECRET_KEY
